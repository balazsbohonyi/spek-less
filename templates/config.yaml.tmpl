# LeanSpec per-project configuration
# Written by install.sh. Skills read this on every invocation.
# See ~/.claude/lean-spec-config.yaml for global defaults (per-project wins when both exist).

# Slash command namespace. Skills are invoked as /<namespace>:<skill>.
# Example: namespace=lean → /lean:plan, /lean:execute, etc.
namespace: {{NAMESPACE}}

# Root directory for spec documents, relative to project root.
specs_root: {{SPECS_ROOT}}

# Feature status lifecycle:
#   created → discussing → planning → executing → verifying → done
# Skills advance status automatically. Manual editing is safe.

# If true, /lean:execute will suggest commits at natural boundaries.
# Default false — respects the user's commit rhythm.
suggest_commits: {{SUGGEST_COMMITS}}

# How many targeted reads/greps worth of exploration before /lean:plan and
# /lean:adopt delegate to an Explore subagent. Lower = more eager delegation.
subagent_threshold: {{SUBAGENT_THRESHOLD}}

# Free-text hints about the project's language, framework, and conventions.
# Skills use these to tailor suggestions. Example:
#   "TypeScript + Bun + React. Prefer functional components. ESM only."
project_hints: "{{PROJECT_HINTS}}"

# Commit message style for /lean:commit. One of:
#   plain         — default, spec-anchored "NNN: summary — tasks 1-3" + bullet body
#   conventional  — conventional commits: "feat(NNN): summary"
#   <free text>   — a custom rule; /lean:commit reads it literally and applies it
# Principles in principles.md override this setting when they declare a more
# specific commit rule (e.g. ticket-number prefixes).
commit_style: {{COMMIT_STYLE}}
