# SpekLess per-project configuration
# Written by install.js. Skills read this on every invocation.
# See ~/.claude/spek-config.yaml for global defaults (per-project wins when both exist).

# Command namespace. Installed skill names are rendered from this namespace.
# Example: namespace=spek → `spek:plan` / `spek:execute` in Claude/OpenCode, `spek-plan` / `spek-execute` in Codex.
namespace: {{NAMESPACE}}

# Root directory for spec documents, relative to project root.
specs_root: {{SPECS_ROOT}}

# Feature status lifecycle:
#   created → discussing → planning → executing → verifying → done
# Skills advance status automatically. Manual editing is safe.

# If true, spek:execute will suggest commits at natural boundaries.
# Default false — respects the user's commit rhythm.
suggest_commits: {{SUGGEST_COMMITS}}

# How many targeted reads/greps worth of exploration before spek:plan and
# spek:adopt delegate to an Explore subagent. Lower = more eager delegation.
subagent_threshold: {{SUBAGENT_THRESHOLD}}

# Commit message style for spek:commit. One of:
#   plain         — default, spec-anchored "NNN: summary — tasks 1-3" + bullet body
#   conventional  — conventional commits: "feat(NNN): summary"
#   <free text>   — a custom rule; spek:commit reads it literally and applies it
# Principles in principles.md override this setting when they declare a more
# specific commit rule (e.g. ticket-number prefixes).
commit_style: {{COMMIT_STYLE}}
